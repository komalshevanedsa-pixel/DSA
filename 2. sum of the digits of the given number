// sum of the digits of the given number

const calculateSumOfDigits = (num) =>{
    let sum = 0;
    while(num>0){
        let digit = num%10;
        sum += digit
        num = Math.floor(num/10);
    }
    return sum;
}
console.log(calculateSumOfDigits(1234)) // 10
console.log(calculateSumOfDigits(87)) //15
